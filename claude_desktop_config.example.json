{
  "_comment": "Copy the 'wind-vane' entry into your Claude Desktop config.json (mcpServers section). Adjust paths and credentials for your environment.",
  "mcpServers": {
    "wind-vane": {
      "command": "uv",
      "args": [
        "--directory",
        "C:\\Users\\YourName\\WindVaneMCP",
        "run",
        "python",
        "-m",
        "wind_vane.server"
      ],
      "env": {
        "DATABASE_URL": "postgresql+asyncpg://windvane:password@localhost:5432/windvane",
        "NOTIFIER_EMAIL_TO": "you@example.com",
        "NOTIFIER_EMAIL_FROM": "windvane@example.com",
        "SMTP_HOST": "smtp.example.com",
        "SMTP_PORT": "587",
        "SMTP_USERNAME": "windvane@example.com",
        "SMTP_PASSWORD": "your_smtp_password",
        "SMTP_USE_TLS": "true",
        "NOTIFIER_ENABLED": "true"
      }
    }
  }
}
